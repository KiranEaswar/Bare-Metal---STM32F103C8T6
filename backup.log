void gpio_init(void){
    RCC->APB2ENR |= (1 << 2);
    RCC->APB2ENR |= (1 << 3);
    GPIOA->CRL &= ~(0xF << 20);
    GPIOA->CRL |=  (0x2 << 20);   // PA5 push-pull output 2MHz
    GPIOA->CRL &= ~(0xF << 0);
    GPIOA->CRL |=  (0x4 << 0);    // PA0 floating input
    GPIOB->CRL &= ~(0xF << 0);
    GPIOB->CRL |=  (0x4 << 0);    // PB0 floating input
}

